# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend CORS
FRONTEND_URL=https://shivamcodes.in

# ==================== RAZORPAY ====================
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ==================== PHONEPE (OAuth Client API) ====================
PHONEPE_CLIENT_ID=your_phonepe_client_id_here
PHONEPE_CLIENT_SECRET=your_phonepe_client_secret_here
PHONEPE_CLIENT_VERSION=1

# ==================== CASHFREE ====================
CASHFREE_APP_ID=your_cashfree_app_id_here
CASHFREE_APP_SECRET=your_cashfree_app_secret_here
CASHFREE_API_URL=https://api.cashfree.com/pg

# ==================== SABPAISA ====================
SABPAISA_CLIENT_CODE=your_sabpaisa_client_code_here
SABPAISA_USERNAME=your_sabpaisa_username_here
SABPAISA_PASSWORD=your_sabpaisa_password_here
SABPAISA_AUTH_KEY=your_sabpaisa_auth_key_here
SABPAISA_AUTH_IV=your_sabpaisa_auth_iv_here
SABPAISA_URL=https://encrypted.sabpaisa.in/SabPaisa/api/Paisa

# ==================== LOGGING ====================
LOG_LEVEL=info
